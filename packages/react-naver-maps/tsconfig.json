{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2023",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "composite": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "types": ["navermaps"],
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.*",
    "**/*.test.*",
    "**/__tests__/**"
  ]
}
