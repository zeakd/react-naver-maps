---
import { getCollection } from 'astro:content';
import { buildNavigation } from 'astro-component-docs';
import '../styles/global.css';

interface Props {
  title: string;
  category?: string;
  slug?: string;
}

const { title, slug } = Astro.props;
const allDocs = await getCollection('docs');
const navigation = buildNavigation(
  allDocs.map((doc) => ({
    slug: doc.slug,
    data: doc.data,
  })),
);

const categoryOrder = ['guides', 'examples', 'api-reference'];

const categoryLabels: Record<string, string> = {
  guides: 'Guides',
  examples: 'Examples',
  'api-reference': 'API Reference',
};

navigation.sort(
  (a, b) =>
    (categoryOrder.indexOf(a.name) ?? 99) -
    (categoryOrder.indexOf(b.name) ?? 99),
);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - react-naver-maps</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={`${import.meta.env.BASE_URL}/`} class="site-logo">
          react-naver-maps
        </a>
        <nav class="site-header-nav">
          <span class="site-version">v0.1</span>
          <a
            href="https://github.com/zeakd/react-naver-maps"
            class="site-github"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <div class="site-container">
      <aside class="site-sidebar">
        {navigation.map((cat) => (
          <div class="sidebar-category">
            <h3 class="sidebar-category-title">
              {categoryLabels[cat.name] ?? cat.name}
            </h3>
            <ul class="sidebar-links">
              {cat.items.map((item) => (
                <li>
                  <a
                    href={`${import.meta.env.BASE_URL}/docs/${item.slug}/`}
                    class:list={[
                      'sidebar-link',
                      { active: item.slug === slug },
                    ]}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <main class="site-main">
        <article class="site-content">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    height: var(--site-header-height);
    border-bottom: 1px solid var(--acd-border);
    background: #fff;
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    height: 100%;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--acd-text);
  }

  .site-logo:hover {
    text-decoration: none;
  }

  .site-header-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-version {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--acd-bg-subtle);
    color: var(--acd-text-muted);
  }

  .site-github {
    font-size: 0.875rem;
    color: var(--acd-text-muted);
  }

  .site-container {
    display: flex;
    max-width: 1440px;
    margin: 0 auto;
  }

  .site-sidebar {
    position: sticky;
    top: var(--site-header-height);
    width: var(--site-sidebar-width);
    height: calc(100vh - var(--site-header-height));
    overflow-y: auto;
    padding: 1.5rem;
    border-right: 1px solid var(--acd-border);
    flex-shrink: 0;
  }

  .sidebar-category {
    margin-bottom: 1.5rem;
  }

  .sidebar-category-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--acd-text-muted);
    margin-bottom: 0.5rem;
  }

  .sidebar-links {
    list-style: none;
  }

  .sidebar-link {
    display: block;
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
    color: var(--acd-text-muted);
    border-radius: 4px;
    transition: background 0.15s;
  }

  .sidebar-link:hover {
    background: var(--acd-bg-subtle);
    color: var(--acd-text);
    text-decoration: none;
  }

  .sidebar-link.active {
    background: #eef2ff;
    color: var(--acd-accent);
    font-weight: 500;
  }

  .site-main {
    flex: 1;
    min-width: 0;
    padding: 2rem 3rem 5rem;
  }

  .site-content {
    max-width: var(--site-content-max-width);
  }

  .site-content :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .site-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--acd-border);
  }

  .site-content :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .site-content :global(p) {
    margin-bottom: 1rem;
  }

  .site-content :global(ul),
  .site-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .site-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .site-content :global(pre) {
    margin: 1rem 0;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
</style>
